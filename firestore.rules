rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: holdings
    // Document ID: auto-generated
    // Fields:
    //   - ticker: string (required, 1-10 chars) - Stock symbol
    //   - shares: number (required, positive) - Quantity
    //   - avg_price: number (required, positive) - Cost basis
    //   - userId: string (required, immutable) - Owner UID
    //   - updatedAt: timestamp (optional) - Last sync
    //
    // Collection: transactions
    // Document ID: auto-generated
    // Fields:
    //   - holdingId: string (required) - Reference to holding
    //   - type: string (required, 'buy' or 'sell')
    //   - shares: number (required, positive)
    //   - price: number (required, positive)
    //   - date: string (required, ISO8601)
    //   - userId: string (required, immutable)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "sumit.sn@gmail.com" && request.auth.token.email_verified == true);
    }

    function isDocOwner() {
      return isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
    }

    function uidUnchanged() {
      return !('userId' in request.resource.data) || 
        request.resource.data.userId == request.auth.uid;
    }

    function uidNotModified() {
      return !('userId' in request.resource.data) || 
        request.resource.data.userId == resource.data.userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Domain Validators
    
    function isValidHolding(data) {
      return hasRequiredFields(['ticker', 'shares', 'avg_price', 'userId']) &&
        hasOnlyAllowedFields(['ticker', 'shares', 'avg_price', 'userId', 'updatedAt', 'portfolioType', 'avgPriceCurrency']) &&
        data.ticker is string && data.ticker.size() >= 1 && data.ticker.size() <= 20 &&
        data.shares is number && data.shares >= 0 &&
        data.avg_price is number && data.avg_price >= 0 &&
        data.userId is string &&
        (!('updatedAt' in data) || data.updatedAt is timestamp) &&
        (!('portfolioType' in data) || data.portfolioType is string) &&
        (!('avgPriceCurrency' in data) || (data.avgPriceCurrency is string && data.avgPriceCurrency.size() <= 10));
    }

    function isValidTransaction(data) {
      return hasRequiredFields(['holdingId', 'type', 'shares', 'price', 'date', 'userId']) &&
        hasOnlyAllowedFields(['holdingId', 'type', 'shares', 'price', 'date', 'userId']) &&
        data.type in ['buy', 'sell'] &&
        data.shares is number && data.shares > 0 &&
        data.price is number && data.price >= 0 &&
        data.date is string &&
        data.userId is string;
    }

    function isValidSettings(data) {
      return hasOnlyAllowedFields(['tabs', 'user']) &&
        (!('tabs' in data) || data.tabs is map) &&
        (!('user' in data) || data.user is map);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /settings/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidSettings(request.resource.data);
    }

    match /holdings/{holdingId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidHolding(request.resource.data) && isOwner(request.resource.data.userId);
      allow update: if isDocOwner() && isValidHolding(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /transactions/{transactionId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidTransaction(request.resource.data) && isOwner(request.resource.data.userId);
      allow update: if isDocOwner() && isValidTransaction(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /backups/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && 
        hasOnlyAllowedFields(['holdings', 'transactions', 'tab', 'timestamp']) &&
        request.resource.data.holdings is list &&
        request.resource.data.transactions is list &&
        request.resource.data.tab is string &&
        request.resource.data.timestamp is string;
      allow delete: if isOwner(userId);
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
